# Server (Render) environment variables — copy to .env locally
# MongoDB connection string (MongoDB Atlas recommended for production)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/loanflow

# JWT secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Port the Express server listens on (Render sets this automatically)
PORT=5000

# Frontend URL(s) allowed by CORS. Comma-separate multiple origins.
# Set to your Vercel URL in production, e.g. https://loanflow.vercel.app
FRONTEND_URL=http://localhost:3000

# Optional: additional comma-separated allowed CORS origins
# ALLOWED_ORIGINS=https://loanflow.vercel.app,https://www.loanflow.com

# Set to "production" on Render to tighten CORS to allowed origins only
NODE_ENV=development